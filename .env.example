# ─── Server ───────────────────────────
PORT=3000

# ─── Redis (BullMQ) ───────────────────
REDIS_URL=redis://localhost:6379
# Controle do Worker
START_WORKER=true
QUEUE_CONCURRENCY=5

# ─── MCP Server ──────────────────────
MCP_SERVER_URL=
MCP_API_KEY=

# ─── LLM Provider ────────────────────
# Providers suportados: openai | anthropic | deepseek
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o

# ─── Auth (JWT) ───────────────────────
# Chave secreta para assinar os tokens JWT (mínimo 32 caracteres recomendado)
JWT_SECRET=your_super_secret_key_here
# Tempo de expiração do token (ex: 8h, 1d, 7d)
JWT_EXPIRES_IN=8h


## 

# ─── Slack ────────────────────────────
# Bot token (começa com xoxb-)
SLACK_BOT_TOKEN=xoxb-
# Signing secret do app (encontrado em App Credentials no Slack API dashboard)
SLACK_SIGNING_SECRET=